# =============================================================================
# Deep Search Portal — Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# --- Mistral AI (used by both proxies) ---
MISTRAL_API_KEY=your-mistral-api-key

# --- Open WebUI Provider API Keys ---
OPENROUTER_API_KEY=sk-or-v1-...
VENICE_API_KEY=VENICE_INFERENCE_KEY_...
TOGETHER_API_KEY=tgp_v1_...
PERPLEXITY_API_KEY=pplx-...
RUNPOD_API_KEY=rpa_...

# --- Google OAuth (for login) ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# --- Cloudflare Tunnel ---
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token

# --- Domain ---
WEBUI_URL=https://your-domain.com

# --- Langfuse LLM Observability (optional, enables per-query trace URLs) ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=http://localhost:3001
LANGFUSE_ENABLED=true
# For self-hosted Langfuse Docker Compose (config/docker-compose.langfuse.yml):
LANGFUSE_ENCRYPTION_KEY=  # generate with: openssl rand -hex 32
LANGFUSE_NEXTAUTH_SECRET=  # generate with: openssl rand -hex 32

# --- Research Reports ---
# Public URL of the portal (used in report links streamed to clients).
# If unset, report links will be relative paths.
PORTAL_PUBLIC_URL=https://staging.deep-search.uk

# --- Open WebUI Auth (for dashboard/report endpoint protection) ---
# Internal URL of the Open WebUI instance used to validate session tokens.
OWUI_INTERNAL_URL=http://localhost:3000
