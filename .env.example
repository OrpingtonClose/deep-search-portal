# =============================================================================
# Deep Search Portal — Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# --- Mistral AI (used by thinking proxy) ---
MISTRAL_API_KEY=your-mistral-api-key

# --- xAI / Grok (used by persistent-miroflow, deep-research, miroflow-sprint) ---
# Grok via xAI direct API bypasses OpenRouter's safety layer.
# See docs/model-evaluation-march-2026.md for the full evaluation.
XAI_API_KEY=xai-...

# --- Venice AI (used by swarm — zero-censorship models) ---
VENICE_API_KEY=VENICE_INFERENCE_KEY_...

# --- OpenRouter (used by G0DM0D3 multi-model proxy) ---
OPENROUTER_API_KEY=sk-or-v1-...

# --- Google OAuth (for LibreChat login) ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# --- LibreChat Secrets (generate with: openssl rand -hex 32) ---
CREDS_KEY=
JWT_SECRET=

# --- LibreChat Domain (public URL for OAuth callbacks) ---
DOMAIN_CLIENT=https://your-domain.com
DOMAIN_SERVER=https://your-domain.com

# --- Cloudflare Tunnel ---
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token

# --- Langfuse LLM Observability (optional, enables per-query trace URLs) ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=http://localhost:3001
LANGFUSE_ENABLED=true
# For self-hosted Langfuse Docker Compose (config/docker-compose.langfuse.yml):
LANGFUSE_ENCRYPTION_KEY=  # generate with: openssl rand -hex 32
LANGFUSE_NEXTAUTH_SECRET=  # generate with: openssl rand -hex 32

# --- Research Reports ---
# Public URL of the portal (used in report links streamed to clients).
# If unset, report links will be relative paths.
PORTAL_PUBLIC_URL=https://staging.deep-search.uk

# --- Gateway Auth (for dashboard/report endpoint protection) ---
# Internal URL of the LibreChat instance used to validate session tokens.
GATEWAY_INTERNAL_URL=http://localhost:3000
