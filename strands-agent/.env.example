# Venice AI (OpenAI-compatible, uncensored)
VENICE_API_KEY=
VENICE_API_BASE=https://api.venice.ai/api/v1
VENICE_MODEL=olafangensan-glm-4.7-flash-heretic

# Tool API keys
BRAVE_API_KEY=
FIRECRAWL_API_KEY=
EXA_API_KEY=
KAGI_API_KEY=

# Observability (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=

# Adaptive loop prevention (optional — defaults shown)
# BASE_TEMPERATURE=0.7
# TEMP_ESCALATION_STEP=0.2
# MAX_TEMPERATURE=1.5
# SIMILARITY_THRESHOLD=0.6
# MAX_SIMILAR_CALLS=3

# LLM Advisor (optional — auto-detects from available API keys)
# Falls back through: OPENROUTER → OPENAI → DEEPSEEK → MISTRAL → XAI → GROQ → GOOGLE
# ADVISOR_API_KEY=          # Explicit key (overrides auto-detect)
# ADVISOR_API_BASE=         # Explicit base URL
# ADVISOR_MODEL=            # Explicit model name
# ADVISOR_MAX_CALLS=5       # Max advisory calls per request
# ADVISOR_MAX_TOKENS=2048   # Max tokens per advisory response
