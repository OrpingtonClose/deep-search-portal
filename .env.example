# =============================================================================
# Deep Search Portal — Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# --- LLM API Keys ---
# Primary: xAI/Grok (uncensored, tool-calling) — used by research proxies
XAI_API_KEY=xai-...
# Fallback: Mistral (used by thinking proxy, fallback for others)
MISTRAL_API_KEY=your-mistral-api-key
# Venice AI (zero-censorship models) — used by swarm proxy
VENICE_API_KEY=VENICE_INFERENCE_KEY_...
# OpenRouter (used by G0DM0D3 multi-model proxy)
OPENROUTER_API_KEY=sk-or-v1-...

# --- Model Configuration (read by all proxies via .env) ---
UPSTREAM_KEY=${XAI_API_KEY}
UPSTREAM_BASE=https://api.x.ai/v1
UPSTREAM_MODEL=grok-3-fast
SUBAGENT_MODEL=grok-3-fast
# Swarm proxy model overrides (defaults to UPSTREAM_MODEL / SUBAGENT_MODEL)
# SWARM_SYNTHESIS_MODEL=grok-3-fast
# SWARM_WORKER_MODEL=grok-3-fast

# --- Google OAuth (for LibreChat login) ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# --- LibreChat Secrets (generate with: openssl rand -hex 32) ---
CREDS_KEY=
JWT_SECRET=

# --- LibreChat Domain (public URL for OAuth callbacks) ---
DOMAIN_CLIENT=https://your-domain.com
DOMAIN_SERVER=https://your-domain.com

# --- Cloudflare Tunnel ---
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token

# --- Langfuse LLM Observability (optional, enables per-query trace URLs) ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=http://localhost:3001
LANGFUSE_ENABLED=true
# For self-hosted Langfuse Docker Compose (config/docker-compose.langfuse.yml):
LANGFUSE_ENCRYPTION_KEY=  # generate with: openssl rand -hex 32
LANGFUSE_NEXTAUTH_SECRET=  # generate with: openssl rand -hex 32

# --- Neo4j + Knowledge Engine ---
# Neo4j must be installed and running for condition persistence and cross-session memory.
# Knowledge Engine (KE) is the API layer on top of Neo4j.
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474
KE_PORT=9850
KNOWLEDGE_ENGINE_URL=http://localhost:9850

# --- Research Reports ---
# Public URL of the portal (used in report links streamed to clients).
# If unset, report links will be relative paths.
PORTAL_PUBLIC_URL=https://staging.deep-search.uk

# --- Direct Provider API Keys (for native routing, bypassing OpenRouter) ---
# If set, models from that provider route directly to their API.
# If unset, they fall back to OpenRouter.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# XAI_API_KEY — already defined above in LLM API Keys section
DEEPSEEK_API_KEY=
MISTRAL_NATIVE_API_KEY=
PERPLEXITY_API_KEY=
MOONSHOT_API_KEY=
COHERE_API_KEY=
MINIMAX_API_KEY=
GROQ_API_KEY=
DASHSCOPE_API_KEY=
STEPFUN_API_KEY=
ZHIPU_API_KEY=
NVIDIA_API_KEY=

# OPENROUTER_API_KEY — already defined above in LLM API Keys section

# --- Gateway Auth (for dashboard/report endpoint protection) ---
# Internal URL of the LibreChat instance used to validate session tokens.
GATEWAY_INTERNAL_URL=http://localhost:3000

# --- LiteLLM Proxy (LLM routing + cost tracking + fallbacks) ---
LITELLM_MASTER_KEY=sk-litellm-master-key
LITELLM_PORT=4000
LITELLM_PROXY_URL=http://localhost:4000

# --- MCP Gateway ---
MCP_GATEWAY_PORT=9800
MCP_DISPATCHER_PORT=9801

# --- Tier Chooser Proxy ---
TIER_CHOOSER_PORT=9900
TIER_CHOOSER_LOG_DIR=/opt/tier_chooser_logs
TIER_CHOOSER_MAX_CONCURRENT=10
TIER_CHOOSER_MODEL_TIMEOUT=90
TIER_CHOOSER_SYNTHESIS_MODEL=google/gemini-3-flash-preview
TIER_CHOOSER_NAMESPACE=tier-chooser
TIER_CHOOSER_IMAGE_ENRICHMENT=true

# --- Media Enrichment (images + videos appended to tier chooser responses) ---
MEDIA_ENRICHMENT_ENABLED=true
MEDIA_ENRICHMENT_MAX_IMAGES=6
MEDIA_ENRICHMENT_MAX_VIDEOS=4
# Brave Search API (image search — runs in parallel with SearXNG)
# Get a free key at https://brave.com/search/api/ (2000 queries/month)
# When set, image search is enriched with Brave results merged with SearXNG.
# When unset, only SearXNG image search is used (graceful degradation).
BRAVE_SEARCH_API_KEY=
# Firecrawl API (deep web scraping/crawling — JS rendering, anti-bot, clean markdown)
# Get a key at https://firecrawl.dev or self-host for unlimited use
FIRECRAWL_API_KEY=
# Exa API (semantic/neural AI search — meaning-based, not just keywords)
# Get a key at https://exa.ai
EXA_API_KEY=

# --- Heretic Proxy (GLM-4.7 Flash Heretic with Firecrawl/Exa/Brave tools) ---
HERETIC_PROXY_PORT=9950
HERETIC_PROXY_LOG_DIR=/opt/heretic_proxy_logs

# TranscriptAPI (YouTube spoken-content search + transcript extraction)
# Sign up at https://transcriptapi.com/onboarding
TRANSCRIPTAPI_KEY=

# --- Search Backend Toggle ---
# "mcp" = new framework-based architecture (LiteLLM + MCP servers + LangGraph dispatcher)
# "legacy" = existing _execute_tool_inner() dispatch (default, no changes to behavior)
SEARCH_BACKEND=mcp
